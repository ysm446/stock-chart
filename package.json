{
  "name": "stock-chart-electron",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dev:renderer": "npm --prefix frontend run dev",
    "dev:electron": "wait-on http-get://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer:web": "npm --prefix frontend run build",
    "build:renderer:electron": "cross-env VITE_API_BASE_URL=http://127.0.0.1:8000/api npm --prefix frontend run build",
    "pack": "npm run build:renderer:electron && electron-builder --dir",
    "dist": "npm run build:renderer:electron && electron-builder"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.stockchart.app",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "frontend/dist",
        "to": "frontend-dist"
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!venv/**",
          "!__pycache__/**",
          "!.pytest_cache/**"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
